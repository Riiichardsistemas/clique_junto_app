# URL COMPLETA da API — precisa do protocolo https:// e terminar em /api.
#
# ATENCAO: sem "https://" o navegador trata o valor como caminho relativo e
# envia o POST para o proprio dominio do frontend, resultando em erro
# 405 Method Not Allowed vindo da Vercel.
#
#   ERRADO:  VITE_API_URL=meu-backend.up.railway.app/api
#   CERTO:   VITE_API_URL=https://meu-backend.up.railway.app/api
#
# Desenvolvimento:
VITE_API_URL=http://localhost:4000/api
#
# Producao (Vercel > Settings > Environment Variables):
# VITE_API_URL=https://cliquejuntoapp-production.up.railway.app/api
#
# Variaveis VITE_ sao embutidas no build. Apos alterar, refaca o deploy
# (Redeploy sem cache) para o novo valor entrar em vigor.

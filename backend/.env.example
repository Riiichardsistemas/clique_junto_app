# Ambiente: development | production
NODE_ENV=development

# Servidor
PORT=4000

# Frontend (para CORS)
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:4000

# Banco de dados
# Em desenvolvimento usamos SQLite automaticamente (nao precisa configurar DATABASE_URL).
# Em producao defina DATABASE_URL apontando para o Postgres.
DATABASE_URL=
# Ex.: postgres://usuario:senha@localhost:5432/era_uma_vez

# Autenticacao
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d

# Token de sessao do convidado (anonimo)
GUEST_JWT_SECRET=troque-este-segredo-de-convidado
GUEST_JWT_EXPIRES_IN=30d

# AWS S3 (etapas futuras)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

# Stripe (etapas futuras)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Email (etapas futuras)
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM="ERA UMA VEZ <no-reply@eraumavez.com>"

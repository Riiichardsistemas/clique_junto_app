# ===== Ambiente =====
NODE_ENV=development           # development | production
PORT=4000

# ===== URLs =====
# FRONTEND_URL aceita múltiplas origens separadas por vírgula (CORS)
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:4000  # URL pública do backend (para links de upload/leitura no modo local)

# ===== Banco de dados =====
# Dev: sem DATABASE_URL usa SQLite automático.
# Produção (Railway): defina a DATABASE_URL do Postgres.
DATABASE_URL=
# Ex.: postgres://usuario:senha@host:5432/railway

# ===== Autenticação (GERE SEGREDOS FORTES EM PRODUÇÃO) =====
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d
GUEST_JWT_SECRET=troque-este-segredo-de-convidado
GUEST_JWT_EXPIRES_IN=30d

# ===== Super-admin =====
# E-mail(s) que viram admin automaticamente ao se cadastrar (separe por vírgula).
# Alternativa: npm run make-admin <email>
ADMIN_EMAIL=

# ===== Pagamento — Asaas =====
# Sem chave = modo mock (dev). Com chave = cobranças reais (Pix/boleto/cartão).
ASAAS_API_KEY=
ASAAS_ENV=sandbox              # sandbox | production
# Token que você define no painel Asaas (Integrações > Webhooks) e aqui, para validar o webhook
ASAAS_WEBHOOK_TOKEN=

# ===== Armazenamento — AWS S3 (recomendado em produção) =====
# Sem AWS_BUCKET_NAME = armazenamento local (NÃO usar em Railway: disco é efêmero).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

# ===== E-mail =====
# Opção 1 (recomendada): Resend
RESEND_API_KEY=
# Opção 2: SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM="CLIQUE JUNTO <no-reply@seudominio.com>"

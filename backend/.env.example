# ===== Ambiente =====
NODE_ENV=development
# Em produção, o Railway injeta PORT automaticamente. Não defina manualmente.
PORT=4000

# ===== URLs =====
# Aceita múltiplas origens exatas separadas por vírgula (Vercel + domínio próprio).
FRONTEND_URL=http://localhost:5173
# URL pública do backend. No Railway, é inferida de RAILWAY_PUBLIC_DOMAIN se ficar vazia.
APP_URL=http://localhost:4000

# ===== Banco de dados =====
# Desenvolvimento: sem DATABASE_URL usa SQLite local.
# Railway: use a referência ${{Postgres.DATABASE_URL}} no painel do serviço da API.
DATABASE_URL=
# auto = SSL em produção; require = sempre; disable = nunca.
DATABASE_SSL=auto
# Railway usa certificado compatível com esta configuração. Ative apenas com CA confiável.
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Opcional para testes locais isolados; `:memory:` não persiste dados.
# SQLITE_STORAGE=:memory:
# Desative apenas quando o schema local já estiver atualizado e quiser inicialização mais rápida.
# DATABASE_SYNC_ALTER=false

# ===== Autenticação =====
# Gere dois valores diferentes com:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d
GUEST_JWT_SECRET=troque-este-segredo-de-convidado
GUEST_JWT_EXPIRES_IN=30d

# ===== Super-admin =====
# E-mails promovidos a super-admin ao se cadastrarem (separe por vírgula).
ADMIN_EMAIL=
# Use somente durante a execução de `npm run create-super-admin` e remova depois.
SUPER_ADMIN_PASSWORD=

# ===== Pagamento — Asaas =====
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=

# ===== Armazenamento =====
# Opção A: S3 (recomendado para escala e múltiplas réplicas).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
# Opção B: Volume Railway. A variável RAILWAY_VOLUME_MOUNT_PATH é detectada automaticamente.
# Fora do Railway, informe um caminho absoluto persistente se desejar.
UPLOADS_DIR=

# ===== E-mail =====
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM="CLIQUE JUNTO <no-reply@seudominio.com>"
